# ── FLUX PRO - User Configuration ─────────────────────────
# Copy this file to config.user and edit the values below.
# Never edit Flux.conf directly — it gets overwritten on launch.

# Your timezone (find yours: timedatectl list-timezones)
TIMEZONE="Asia/Kathmandu"

# Widget position: top_right, top_left, bottom_right, bottom_left
ALIGNMENT="top_right"

# Gap from screen edge in pixels (adjust for your resolution/scaling)
GAP_X=50
GAP_Y=70

# Final Conky window mode
# Valid values: normal, dock, panel, desktop, utility, override
WINDOW_TYPE="override"

# Startup behavior:
# auto   = start once in normal mode, then switch to WINDOW_TYPE
# direct = start directly in WINDOW_TYPE
STARTUP_MODE="auto"

# ── Weather ───────────────────────────────────────────────
# City query format: "CityName,xx" where xx = 2-letter country code
# Examples: "London,gb" / "Tokyo,jp" / "New York,us"
CITY_QUERY="Kathmandu,np"

# Free API key from https://openweathermap.org/api
API_KEY="your_openweathermap_api_key_here"
